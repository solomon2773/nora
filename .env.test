# Test-only environment for local/CI automation.
# Contains dummy non-production values only.

JWT_SECRET=test-jwt-secret-for-ci-only-please-change-in-real-envs
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

DB_HOST=postgres
DB_USER=platform
DB_PASSWORD=platform
DB_NAME=platform
DB_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379
PORT=4000

OAUTH_LOGIN_ENABLED=false
NEXT_PUBLIC_OAUTH_LOGIN_ENABLED=false
NEXTAUTH_SECRET=test-nextauth-secret-for-ci-only
NEXTAUTH_URL=http://127.0.0.1:18080

PLATFORM_MODE=selfhosted
MAX_VCPU=16
MAX_RAM_MB=32768
MAX_DISK_GB=500
MAX_AGENTS=50

BILLING_ENABLED=false
PROVISIONER_BACKEND=docker
NEMOCLAW_ENABLED=false
KEY_STORAGE=database
CORS_ORIGINS=http://127.0.0.1:18080,http://localhost:18080
