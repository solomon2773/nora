# Nora Environment Configuration Example

# JWT secret used for authentication
JWT_SECRET=change-me

# PostgreSQL configuration
DB_HOST=postgres
DB_PORT=5432
DB_USER=platform
DB_PASSWORD=platform
DB_NAME=platform

# API port
PORT=4000

# Optional: Docker socket location
DOCKER_SOCKET=/var/run/docker.sock

# Optional: Logging level
LOG_LEVEL=info
